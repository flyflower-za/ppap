# Application
SECRET_KEY=change-this-to-a-random-string-in-production
DEBUG=false

# Database
POSTGRES_DB=ppap
POSTGRES_USER=ppap
POSTGRES_PASSWORD=ppap123

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Redis
REDIS_PASSWORD=change-this-redis-password

# Aliyun AI (optional)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Email (optional)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# CORS
# 生产环境请将 APP_BASE_URL 也加入此列表
CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# 应用对外访问的根 URL（生产环境改为实际域名或 IP）
APP_BASE_URL=http://localhost

# SSO / OIDC
# 回调地址：需与 Keycloak/OIDC 服务商中配置的 Redirect URI 完全一致
# 留空则自动使用 APP_BASE_URL + /auth/callback
OIDC_REDIRECT_URI=
# 手动配置 Keycloak/OIDC Issuer 地址（不使用发现端点时填写）
OIDC_ISSUER_BASE_URL=

# Admin Password Hash (可选)
# 默认密码是 admin123，首次登录后请通过系统修改密码
# 如需预设置不同的管理员密码，使用 Python 生成哈希：
# python -c "import bcrypt; print(bcrypt.hashpw('your-password'.encode(), bcrypt.gensalt()).decode())"
# 然后将生成的哈希值写入下方（需要特殊处理 $ 符号，建议通过系统修改密码）
