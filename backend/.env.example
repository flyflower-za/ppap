# Application
APP_NAME="PPAP File Verification Platform"
APP_VERSION="1.0.0"
DEBUG=true
API_PREFIX="/api/v1"

# Server
HOST=0.0.0.0
PORT=31234

# Database
DATABASE_URL=postgresql+asyncpg://ppap:ppap123@localhost:5432/ppap

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT / Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SSO / LDAP
SSO_ENABLED=false
SSO_PROVIDER=
LDAP_URL=

# File Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ppap-files
MINIO_SECURE=false

# File Upload
MAX_FILE_SIZE=52428800

# Aliyun AI
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_AGENT_ENDPOINT=

# Email / SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# File Retention
FILE_RETENTION_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
